{
  "functions": {
    "api/stripe.js": {
      "memory": 256
    },
    "api/auth.js": {
      "memory": 256
    },
    "api/claude.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/stripe/checkout",
      "destination": "/api/stripe"
    },
    {
      "source": "/api/stripe/webhook",
      "destination": "/api/stripe"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}

// ── ENVIRONMENT VARIABLES ──────────────────────────────────────────────────
// Add ALL of these in: Vercel Dashboard → Project → Settings → Environment Variables
// Set for: Production + Preview + Development
//
// SUPABASE_URL              → Settings → API → Project URL
// SUPABASE_SERVICE_KEY      → Settings → API → service_role key (NOT anon key)
// ANTHROPIC_API_KEY         → console.anthropic.com/keys
// RESEND_API_KEY            → resend.com → API Keys
// STRIPE_SECRET_KEY         → dashboard.stripe.com → Developers → API Keys → Secret key
// STRIPE_WEBHOOK_SECRET     → dashboard.stripe.com → Developers → Webhooks → signing secret
// STRIPE_PRICE_ID           → dashboard.stripe.com → Products → your $9/mo price → Price ID (price_xxx)
// APP_URL                   → https://tooldexo.com  (no trailing slash)
