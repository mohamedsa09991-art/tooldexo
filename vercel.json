{
  "functions": {
    "api/auth.js": { "memory": 256 },
    "api/claude.js": { "memory": 256, "maxDuration": 30 },
    "api/stripe.js": { "memory": 256 }
  },
  "rewrites": [
    { "source": "/api/auth/verify", "destination": "/api/auth" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/api/stripe/checkout", "destination": "/api/stripe" },
    { "source": "/api/stripe/webhook", "destination": "/api/stripe" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
